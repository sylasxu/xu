# ==========================================
# xu Application Environment Variables
# ==========================================

# Database Configuration
DATABASE_URL=postgresql://postgres:your_secure_password_here@localhost:5432/xu

# Redis Configuration  
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your_redis_password_here

# API Configuration
API_PORT=3000
API_HOST=0.0.0.0  # 监听地址：0.0.0.0 支持局域网访问，127.0.0.1 仅本机
API_BASE_URL=http://localhost:3000
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Vite 前端环境变量（需要 VITE_ 前缀才能在前端访问）
VITE_API_BASE_URL=http://localhost:3000

# WeChat Mini Program Configuration
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret
# 认证 Mock 开关（仅本地联调时按需开启）
# WECHAT_AUTH_MOCK_LOGIN=false
# WECHAT_AUTH_MOCK_OPENID=wx_mock_openid
# WECHAT_AUTH_MOCK_SESSION_KEY=mock_session_key
# WECHAT_AUTH_MOCK_PHONE=false
# WECHAT_AUTH_MOCK_PHONE_NUMBER=13800138000
# 内容审核 Mock 开关（仅本地联调时按需开启）
# WECHAT_MSG_SEC_CHECK_MOCK=false

# WeChat Service Notifications (订阅消息)
# 未配置模板 ID 时，系统会自动降级为仅站内通知
# WECHAT_NOTIFY_TEMPLATE_ID_POST_ACTIVITY=
# WECHAT_NOTIFY_TEMPLATE_ID_ACTIVITY_REMINDER=
# WECHAT_NOTIFY_TEMPLATE_ID_DISCUSSION_REPLY=
# WECHAT_NOTIFY_TEMPLATE_ID_MATCH_REASSIGNED=
# WECHAT_NOTIFY_PAGE_POST_ACTIVITY=pages/message/index
# WECHAT_NOTIFY_PAGE_ACTIVITY_REMINDER=pages/message/index
# WECHAT_NOTIFY_PAGE_DISCUSSION_REPLY=subpackages/activity/discussion/index
# WECHAT_NOTIFY_PAGE_MATCH_REASSIGNED=pages/message/index
# WECHAT_NOTIFY_MINIPROGRAM_STATE=formal
# WECHAT_NOTIFY_LANG=zh_CN
# WECHAT_NOTIFY_MOCK=true

# AI Service Configuration (支持 Moonshot / Qwen)

# ==========================================
# AI 模型配置 - 按用途分类
# ==========================================

# --- Chat / Agent 主力模型（推荐） ---
# 推荐: Moonshot / Kimi（境内部署优先）
MOONSHOT_API_KEY=your_moonshot_api_key
# MOONSHOT_BASE_URL=https://api.moonshot.cn/v1

# --- Embedding 模型 ---
# Qwen 仅用于 Embedding（阿里云百炼 OpenAI 兼容接口）
DASHSCOPE_API_KEY=your_dashscope_api_key
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  # 默认值

# --- Embedding ---
# 使用同一套 DashScope 凭证（Qwen text-embedding-v4）

# --- OpenAI 兼容网关（仅本地调试/迁移兼容，可选） ---
# OPENAI_API_KEY=optional_openai_compatible_api_key
# OPENAI_BASE_URL=https://your-openai-compatible-gateway.example.com/v1
# OPENAI_ORG_ID=
# OPENAI_PROJECT=

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760  # 10MB in bytes
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,gif,webp

# Security Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d
ADMIN_PHONE_WHITELIST=13996092317
ADMIN_SUPER_CODE=replace_with_a_secure_code

# Environment
NODE_ENV=development
DEBUG=true

# Tencent Map Configuration (Admin 位置上下文调试)
VITE_TENCENT_MAP_KEY=your_tencent_map_key_here

# Docker Configuration (for local development)
POSTGRES_DB=xu
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_PORT=5432
REDIS_PORT=6379
