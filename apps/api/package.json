{
  "name": "@xu/api",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/types.ts",
  "exports": {
    ".": {
      "types": "./src/types.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "scripts": {
    "dev": "bun run --watch --silent src/index.ts",
    "dev:verbose": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:pbt": "bun test --test-name-pattern 'Property'",
    "genui:regression:turns": "bun ../../scripts/genui-turns-regression.ts",
    "genui:regression:parity": "bun ../../scripts/genui-parity-regression.ts",
    "genui:regression:snapshot": "bun ../../scripts/genui-turns-snapshot.ts",
    "genui:regression": "bun ../../scripts/genui-turns-regression.ts && bun ../../scripts/genui-parity-regression.ts && bun ../../scripts/genui-turns-snapshot.ts"
  },
  "dependencies": {
    "@ai-sdk/moonshotai": "^2.0.0",
    "@ai-sdk/openai": "^3.0.13",
    "@elysiajs/cors": "^1.1.1",
    "@elysiajs/eden": "^1.4.5",
    "@elysiajs/jwt": "^1.1.0",
    "@elysiajs/openapi": "^1.1.0",
    "@xu/db": "workspace:*",
    "@xu/genui-contract": "workspace:*",
    "@xu/utils": "workspace:*",
    "ai": "^6.0.5",
    "chalk": "^5.6.2",
    "dotenv": "^17.2.3",
    "elysia": "^1.1.0",
    "jose": "^6.1.3",
    "pino": "^10.1.0",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@xu/ts-config": "workspace:*",
    "@types/node": "^24.10.1",
    "fast-check": "^3.23.2",
    "typescript": "^5.9.3"
  }
}
