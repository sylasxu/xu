{
  "pages": [
    "pages/chat/index",
    "pages/profile/index",
    "pages/message/index"
  ],
  "subpackages": [
    {
      "root": "subpackages/activity",
      "name": "activity",
      "pages": [
        "detail/index",
        "create/index",
        "confirm/index",
        "draft-edit/index",
        "list/index",
        "explore/index",
        "map-picker/index",
        "discussion/index"
      ]
    },
    {
      "root": "subpackages/legal",
      "name": "legal",
      "pages": ["index", "about/index"]
    },
    {
      "root": "pages/login",
      "name": "login",
      "pages": ["login"]
    },
    {
      "root": "pages/setting",
      "name": "setting",
      "pages": ["index"]
    }
  ],
  "window": {
    "backgroundTextStyle": "light",
    "navigationBarBackgroundColor": "#FAFBFC",
    "navigationBarTitleText": "xu",
    "navigationBarTextStyle": "black",
    "navigationStyle": "custom",
    "backgroundColor": "#FAFBFC"
  },
  "darkmode": true,
  "themeLocation": "theme.json",
  "resolveAlias": {
    "~/*": "/*"
  },
  "sitemapLocation": "sitemap.json",
  "permission": {
    "scope.userLocation": {
      "desc": "你的位置信息将用于显示附近的活动"
    }
  },
  "requiredPrivateInfos": [
    "getLocation",
    "chooseLocation"
  ]
}
