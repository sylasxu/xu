<view class="agent-task-panel">
  <view class="agent-task-panel__header">
    <text class="agent-task-panel__eyebrow">{{eyebrow}}</text>
    <text class="agent-task-panel__title">{{title}}</text>
  </view>

  <view class="agent-task-panel__list">
    <view wx:for="{{tasks}}" wx:key="id" class="agent-task-card agent-task-card--{{item.attentionLevel || 'normal'}}">
      <view class="agent-task-card__meta">
        <view wx:if="{{item.attentionLevel}}" class="agent-task-card__signal agent-task-card__signal--{{item.attentionLevel}}"></view>
        <text class="agent-task-card__type">{{item.taskTypeLabel}}</text>
        <text class="agent-task-card__dot">·</text>
        <text class="agent-task-card__stage">{{item.stageLabel}}</text>
      </view>

      <text class="agent-task-card__headline">{{item.headline}}</text>
      <text wx:if="{{item.activityTitle}}" class="agent-task-card__activity">{{item.activityTitle}}</text>
      <text class="agent-task-card__summary">{{item.summary}}</text>

      <view wx:if="{{item.primaryAction || item.secondaryAction}}" class="agent-task-card__actions">
        <view
          wx:if="{{item.primaryAction}}"
          class="agent-task-card__action agent-task-card__action--primary"
          data-task-index="{{index}}"
          bindtap="onPrimaryTap"
        >
          <text>{{item.primaryAction.label}}</text>
        </view>
        <view
          wx:if="{{item.secondaryAction}}"
          class="agent-task-card__action agent-task-card__action--secondary"
          data-task-index="{{index}}"
          bindtap="onSecondaryTap"
        >
          <text>{{item.secondaryAction.label}}</text>
        </view>
      </view>
    </view>
  </view>

  <view wx:if="{{secondaryCount > 0}}" class="agent-task-panel__secondary">
    <text>还有 {{secondaryCount}} 件进展在消息中心</text>
  </view>
</view>
