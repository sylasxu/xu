<!--
  AI Dock 组件 (Floating Capsule)
  Requirements: 5.1, 5.2, 5.3, 5.4, 5.5, 5.7, 5.8, 15.1, 15.17
  
  Chat-First 架构的超级输入坞
  - 悬浮胶囊样式
  - Halo Card 渐变边框效果
  - 输入框 + 快捷按钮
-->
<view 
  class="ai-dock {{isFocused ? 'focused' : ''}} {{disabled ? 'disabled' : ''}}"
  style="bottom: calc({{bottomOffset}}rpx + env(safe-area-inset-bottom));"
>
  <view class="dock-main-row">
    <!-- 快捷按钮区域 -->
    <view class="dock-actions" wx:if="{{!isFocused && !inputValue}}">
      <!-- 粘贴按钮 -->
      <view 
        class="action-btn btn-pressable" 
        bindtap="onPasteTap"
        hover-class="action-btn--hover"
      >
        <t-icon name="file-paste" size="36rpx" />
      </view>
    </view>
    
    <!-- 输入区域 -->
    <view class="dock-input-wrapper">
      <input
        class="dock-input"
        type="text"
        placeholder="{{placeholder}}"
        placeholder-class="dock-placeholder"
        value="{{inputValue}}"
        disabled="{{disabled}}"
        confirm-type="send"
        adjust-position="{{false}}"
        bindinput="onInputChange"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
        bindconfirm="onInputConfirm"
      />
      
      <!-- 清空按钮 -->
      <view 
        wx:if="{{inputValue}}" 
        class="clear-btn btn-pressable" 
        catchtap="onClearTap"
      >
        <t-icon name="close-circle-filled" size="36rpx" color="var(--text-tertiary)" />
      </view>
    </view>
    
    <!-- 发送按钮 -->
    <view 
      class="send-btn btn-pressable {{canSend ? 'is-ready' : 'is-disabled'}}" 
      bindtap="onSendTap"
      hover-class="send-btn--hover"
    >
      <t-icon name="arrow-up" size="40rpx" color="currentColor" />
    </view>
  </view>
  
  <view class="dock-secondary-row" wx:if="{{isFocused}}">
    <view class="consultant-chip">
      <t-icon name="task" size="30rpx" />
      <text class="consultant-text">未选择咨询人</text>
    </view>
    <view class="profile-link btn-pressable" bindtap="onViewProfileTap">
      <text class="profile-text">查看档案</text>
      <t-icon name="chevron-right" size="28rpx" />
    </view>
  </view>
</view>
