<!--
  Chat Sender 组件
  Requirements: 2.1, 2.2, 2.5
  
  位置：Tabbar上方悬浮
  外观：类似灵动岛的黑色长条
-->
<view class="chat-sender {{isExpanded ? 'expanded' : ''}} {{welcome ? 'chat-sender--welcome' : 'chat-sender--chat'}}">
  <!-- 收起状态：点击展开 -->
  <view wx:if="{{!isExpanded}}" class="chat-sender__collapsed" bindtap="onBarTap">
    <view class="chat-sender__icon">
      <text>🤖</text>
    </view>
    <view class="chat-sender__placeholder">{{placeholder}}</view>
    <view class="chat-sender__send-btn">
      <t-icon name="arrow-up" size="40rpx" color="#5B75FB" />
    </view>
  </view>

  <!-- 展开状态：输入框 -->
  <view wx:else class="chat-sender__expanded">
    <view class="chat-sender__icon">
      <text>🤖</text>
    </view>
    
    <view class="chat-sender__input-wrapper">
      <input
        class="chat-sender__input"
        type="text"
        placeholder="{{placeholder}}"
        placeholder-class="chat-sender__input-placeholder"
        value="{{inputValue}}"
        focus="{{isExpanded}}"
        confirm-type="send"
        bindinput="onInputChange"
        bindfocus="onInputFocus"
        bindblur="onInputBlur"
        bindconfirm="onInputConfirm"
      />
      
      <!-- 清空按钮 -->
      <view wx:if="{{inputValue}}" class="chat-sender__clear-btn" catchtap="onClearTap">
        <t-icon name="close-circle-filled" size="36rpx" color="#999" />
      </view>
    </view>

    <view class="chat-sender__action-btn {{inputValue ? 'chat-sender__action-btn--active' : ''}}" catchtap="onInputConfirm">
      <t-icon name="arrow-up" size="44rpx" color="{{inputValue ? '#FFFFFF' : '#5B75FB'}}" />
    </view>
  </view>
</view>
