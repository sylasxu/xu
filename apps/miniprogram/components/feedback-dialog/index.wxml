<!--
  差评反馈弹窗组件
  Requirements: 13.1, 13.2, 13.3, 13.4
-->
<view class="feedback-dialog-mask" wx:if="{{visible}}" bind:tap="onClose">
  <view class="feedback-dialog" catch:tap="noop">
    <!-- 头部 -->
    <view class="feedback-dialog__header">
      <text class="feedback-dialog__title">{{title}}</text>
      <view class="feedback-dialog__close" bind:tap="onClose">
        <t-icon name="close" size="44rpx" />
      </view>
    </view>

    <!-- 步骤1：选择问题类型 -->
    <view class="feedback-dialog__body" wx:if="{{step === 1}}">
      <view class="feedback-dialog__actions">
        <view class="good-btn" bind:tap="onGoodFeedback">
          <t-icon name="thumb-up" size="48rpx" />
          <text>{{positiveLabel}}</text>
        </view>
        <view class="problem-btn" bind:tap="onNextStep" wx:if="{{selectedProblem}}">
          <t-icon name="thumb-down" size="48rpx" />
          <text>{{negativeLabel}}</text>
        </view>
      </view>

      <view class="feedback-dialog__section-title">{{problemSectionTitle}}</view>
      <view class="feedback-dialog__problem-grid">
        <view
          wx:for="{{problemOptions}}"
          wx:key="value"
          class="problem-option {{selectedProblem === item.value ? 'selected' : ''}}"
          data-value="{{item.value}}"
          bind:tap="onSelectProblem"
        >
          <t-icon name="{{item.icon}}" size="44rpx" />
          <text>{{item.label}}</text>
        </view>
      </view>

      <view class="feedback-dialog__footer safe-bottom">
        <t-button theme="primary" size="large" block disabled="{{!selectedProblem}}" bind:tap="onNextStep">
          {{nextStepLabel}}
        </t-button>
      </view>
    </view>

    <!-- 步骤2：选择反馈对象 -->
    <view class="feedback-dialog__body" wx:if="{{step === 2}}">
      <view class="feedback-dialog__back" bind:tap="onPrevStep">
        <t-icon name="chevron-left" size="40rpx" />
        <text>{{backLabel}}</text>
      </view>

      <view class="feedback-dialog__section-title">{{targetSectionTitle}}</view>
      <view class="feedback-dialog__target-list">
        <view
          wx:for="{{participants}}"
          wx:key="userId"
          class="target-item {{selectedTargets.includes(item.userId) ? 'selected' : ''}}"
          data-user-id="{{item.userId}}"
          bind:tap="onToggleTarget"
        >
          <image class="target-item__avatar" src="{{item.avatarUrl || '/static/images/default-avatar.png'}}" mode="aspectFill" />
          <text class="target-item__name">{{item.nickname}}</text>
          <t-checkbox checked="{{selectedTargets.includes(item.userId)}}" icon="circle" borderless />
        </view>
      </view>

      <view class="feedback-dialog__description">
        <view class="feedback-dialog__section-title">{{descriptionSectionTitle}}</view>
        <textarea
          class="feedback-dialog__textarea"
          placeholder="{{descriptionPlaceholder}}"
          value="{{description}}"
          maxlength="200"
          bindinput="onDescriptionInput"
        />
        <view class="feedback-dialog__count">{{description.length}}/200</view>
      </view>

      <view class="feedback-dialog__footer safe-bottom">
        <t-button theme="primary" size="large" block disabled="{{selectedTargets.length === 0}}" loading="{{submitting}}" bind:tap="onSubmit">
          {{submitLabel}}
        </t-button>
      </view>
    </view>
  </view>
</view>
