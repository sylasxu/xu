<!--
  举报弹窗组件
  Requirements: 7.3, 7.4
-->
<t-popup
  visible="{{visible}}"
  placement="bottom"
  bind:visible-change="onClose"
>
  <view class="report-sheet" catchtouchmove="noop">
    <!-- 标题栏 -->
    <view class="report-sheet__header">
      <text class="report-sheet__title">{{type === 'activity' ? titleByType.activity : type === 'message' ? titleByType.message : titleByType.user}}</text>
      <view class="close-btn" bindtap="onClose">
        <text class="report-sheet__close-icon">✕</text>
      </view>
    </view>

    <!-- 举报原因选择 -->
    <view class="report-sheet__section">
      <text class="report-sheet__label">{{sectionTitles.reason}}</text>
      <t-radio-group
        value="{{selectedReason}}"
        bind:change="onReasonChange"
      >
        <view class="report-sheet__options">
          <t-radio
            wx:for="{{reasonOptions}}"
            wx:key="value"
            value="{{item.value}}"
            label="{{item.label}}"
            borderless
          />
        </view>
      </t-radio-group>
    </view>

    <!-- 举报说明 -->
    <view class="report-sheet__section report-sheet__section--compact">
      <text class="report-sheet__label report-sheet__label--compact">{{sectionTitles.description}}</text>
      <t-textarea
        value="{{description}}"
        placeholder="{{descriptionPlaceholder}}"
        maxlength="{{500}}"
        autosize
        bind:change="onDescriptionInput"
      />
    </view>

    <!-- 提交按钮 -->
    <view class="report-sheet__footer safe-bottom">
      <t-button
        theme="primary"
        block
        loading="{{submitting}}"
        disabled="{{!selectedReason || submitting}}"
        bindtap="onSubmit"
      >
        {{submitLabel}}
      </t-button>
    </view>
  </view>
</t-popup>
