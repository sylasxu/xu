<!--
  社交档案卡片组件
  v4.4 新增
  
  展示用户社交统计数据，引导完善偏好
-->
<view class="social-profile-card" wx:if="{{hasProfile}}">
  <view class="card-header {{collapsible ? 'btn-pressable' : ''}}" bindtap="onToggle">
    <view class="header-left">
      <text class="header-icon"></text>
      <text class="header-title">我的社交状态</text>
    </view>
    <view wx:if="{{collapsible}}" class="header-right">
      <t-icon 
        name="{{isExpanded ? 'chevron-up' : 'chevron-down'}}" 
        size="32rpx" 
        color="#9CA3AF"
      />
    </view>
  </view>
  
  <view class="card-content {{isExpanded ? 'expanded' : 'collapsed'}} {{!collapsible ? 'card-content--static' : ''}}">
    <view class="stats-row">
      <view class="stat-item">
        <text class="stat-label">参与</text>
        <text class="stat-value">{{displayProfile.joinedActivities}}</text>
        <text class="stat-unit">场</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-label">发起</text>
        <text class="stat-value">{{displayProfile.hostedActivities}}</text>
        <text class="stat-unit">场</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-label">偏好完善</text>
        <text class="stat-value">{{displayProfile.preferenceCompleteness}}</text>
        <text class="stat-unit">%</text>
      </view>
    </view>
    
    <view class="preference-guide">
      <view class="guide-content">
        <text class="guide-text">{{completenessText}}</text>
      </view>
      <view wx:if="{{collapsible}}" class="guide-action btn-pressable" bindtap="onGoToPreference">
        <text class="action-text">去完善</text>
        <t-icon name="chevron-right" size="28rpx" color="#5B75FB" />
      </view>
    </view>
  </view>
</view>
