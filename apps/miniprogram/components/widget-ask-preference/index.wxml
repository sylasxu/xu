<!--
  Widget Ask Preference 组件
  Requirements: 13.1, 13.2, 13.3, 13.4, 13.5
  
  多轮对话信息收集卡片
  - 显示 AI 询问的问题
  - 渲染选项按钮供用户快速选择
  - 支持"随便/都可以"跳过按钮
-->
<view class="widget-ask-preference {{(disabled || isSubmitting) ? 'widget--disabled' : ''}}">
  <!-- 选项按钮列表 -->
  <view class="options-section">
    <view 
      wx:for="{{options}}" 
      wx:key="value"
      class="option-btn btn-pressable {{(disabled || isSubmitting) ? 'option-btn--disabled' : ''}}"
      data-option="{{item}}"
      bindtap="onSelectOption"
    >
      <text class="option-label">{{item.label}}</text>
    </view>
  </view>

  <view wx:if="{{inputMode === 'free-text-optional'}}" class="custom-location-section">
    <text class="custom-location-title">上面都不合适？直接输入片区</text>
    <text class="custom-location-desc">直接输入你常活动的地方，我会按这里继续筛。</text>
    <view class="custom-location-row">
      <input
        class="custom-location-input"
        type="text"
        maxlength="24"
        placeholder="比如大学城、沙坪坝、两路口"
        value="{{customLocation}}"
        disabled="{{disabled || isSubmitting}}"
        bindinput="onCustomLocationInput"
      />
      <view
        class="custom-location-submit btn-pressable {{(!customLocation || disabled || isSubmitting) ? 'custom-location-submit--disabled' : ''}}"
        bindtap="onSubmitCustomLocation"
      >
        <text class="custom-location-submit__text">使用该区域</text>
      </view>
    </view>
  </view>
</view>
