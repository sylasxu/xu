<!--
  Widget Explore 组件 (Generative UI)
  Requirements: 17.1-17.6, 4.1-4.6, 5.1, 5.4, 5.5, 7.2, 7.5
  
  支持两种模式：
  - 自包含模式（无 fetchConfig）：现有行为不变
  - 引用模式（有 fetchConfig）：Swiper + 半屏详情 + 卡内操作
-->
<view class="widget-explore halo-card {{showHeader ? '' : 'widget-explore--frameless'}} {{presentation === 'immersive-carousel' ? 'widget-explore--immersive' : 'widget-explore--compact'}}">
  <!-- 头部 -->
  <view wx:if="{{showHeader}}" class="explore-header">
    <view class="header-icon icon-circle icon-circle--blue">
      <t-icon name="location" size="40rpx" />
    </view>
    <text class="header-title">{{headerTitle}}</text>
  </view>

  <!-- ========== 引用模式：加载中 ========== -->
  <block wx:if="{{fetchConfig && fetchState === 'loading'}}">
    <!-- preview 预览 -->
    <view wx:if="{{preview}}" class="explore-preview">
      <view class="preview-item">
        <text class="preview-title">{{preview.firstItem.title}}</text>
        <text class="preview-meta">{{preview.firstItem.locationName}} · {{preview.firstItem.type}}</text>
      </view>
      <view class="preview-hint">
        <text>共 {{preview.total}} 个活动，加载中...</text>
      </view>
    </view>
    <!-- 骨架屏 -->
    <view wx:else class="explore-skeleton">
      <view class="skeleton-card"></view>
      <view class="skeleton-card skeleton-card--short"></view>
    </view>
  </block>

  <!-- ========== 引用模式：加载失败 ========== -->
  <block wx:elif="{{fetchConfig && fetchState === 'error'}}">
    <view class="explore-error">
      <text class="error-text">加载失败</text>
      <view class="error-retry btn-pressable" bindtap="onRetryFetch">
        <text>点击重试</text>
      </view>
    </view>
  </block>

  <!-- ========== Swiper 模式（引用模式 + swipeable） ========== -->
  <block wx:elif="{{swiperMode && displayResults.length > 0}}">
    <view class="explore-swiper-shell">
      <view class="explore-swiper-mask explore-swiper-mask--left"></view>
      <view class="explore-swiper-mask explore-swiper-mask--right"></view>
      <swiper
        class="explore-swiper"
        indicator-dots="{{true}}"
        indicator-color="rgba(72, 86, 232, 0.16)"
        indicator-active-color="#5B75FB"
        circular="{{false}}"
        current="{{activeIndex}}"
        previous-margin="72rpx"
        next-margin="72rpx"
        easing-function="easeOutCubic"
        duration="260"
        bindchange="onSwiperChange"
      >
        <swiper-item
          wx:for="{{displayResults}}"
          wx:key="id"
          class="swiper-slide"
        >
          <view class="swiper-card {{activeIndex === index ? 'is-active' : ''}}" data-id="{{item.id}}" bindtap="onActivityTap">
            <view class="swiper-card__body">
              <text class="swiper-card__title">{{item.title}}</text>
              <view class="swiper-card__meta">
                <text class="meta-tag">{{item.type}}</text>
                <text class="meta-dot">·</text>
                <text>{{item.locationName}}</text>
              </view>
              <view class="swiper-card__info">
                <view class="info-item">
                  <t-icon name="time" size="28rpx" color="#9CA3AF" />
                  <text>{{item.startAt}}</text>
                </view>
                <view class="info-item">
                  <t-icon name="location" size="28rpx" color="#9CA3AF" />
                  <text>{{item.distance >= 1000 ? (item.distance / 1000).toFixed(1) + 'km' : item.distance + 'm'}}</text>
                </view>
              </view>
            </view>

            <!-- 卡内操作按钮 -->
            <view wx:if="{{interaction.actions}}" class="swiper-card__actions">
              <view
                wx:for="{{interaction.actions}}"
                wx:for-item="action"
                wx:key="type"
                class="card-action-btn btn-pressable {{actionStates[item.id + '_' + action.type] === 'loading' ? 'is-loading' : ''}} {{actionStates[item.id + '_' + action.type] === 'success' ? 'is-success' : ''}}"
                data-actiontype="{{action.type}}"
                data-activityid="{{item.id}}"
                data-activitytitle="{{item.title}}"
                data-startat="{{item.startAt}}"
                data-locationname="{{item.locationName}}"
                data-actionparams="{{action.params}}"
                catchtap="onActionTap"
              >
                <text wx:if="{{actionStates[item.id + '_' + action.type] === 'loading'}}">...</text>
                <text wx:elif="{{actionStates[item.id + '_' + action.type] === 'success'}}">{{action.type === 'join' ? '已报名' : action.label}}</text>
                <text wx:else>{{action.label}}</text>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- Swiper 计数器 -->
    <view class="swiper-counter">
      <text>{{activeIndex + 1}} / {{displayResults.length}}</text>
    </view>
  </block>

  <!-- ========== 自包含模式（现有行为不变） ========== -->
  <block wx:elif="{{!fetchConfig || fetchState === 'idle'}}">
    <!-- 位置卡片 -->
    <view class="location-card" bindtap="onLocationTap">
      <view class="location-card__icon">
        <t-icon name="map" size="48rpx" color="#5B75FB" />
      </view>
      <view class="location-card__content">
        <text class="location-card__name">{{center.name || '附近'}}周边</text>
        <text class="location-card__hint">点击展开完整地图</text>
      </view>
      <view class="location-card__arrow">
        <t-icon name="chevron-right" size="32rpx" color="#9CA3AF" />
      </view>
    </view>

    <!-- 活动列表 -->
    <view wx:if="{{displayResults.length > 0}}" class="explore-list">
      <view
        wx:for="{{displayResults}}"
        wx:key="id"
        class="explore-item"
        data-id="{{item.id}}"
        bindtap="onActivityTap"
      >
        <activity-list-item
          activity="{{item}}"
          showDistance="{{true}}"
        />
      </view>
    </view>

    <!-- 空状态 -->
    <view wx:else class="explore-empty">
      <text class="empty-text">附近还没有合适的局</text>
      <view class="empty-cta btn-pressable" bindtap="onCreateActivityTap">
        <text>那我来发起一个</text>
      </view>
    </view>
  </block>

  <!-- 展开地图按钮 -->
  <view class="explore-action">
    <view class="action-btn action-btn--secondary btn-pressable" bindtap="onExpandMap">
      <t-icon name="map" size="32rpx" />
      <text>展开地图查看更多</text>
    </view>
  </view>

  <!-- 半屏详情 -->
  <half-screen-detail
    visible="{{halfScreenVisible}}"
    activityId="{{halfScreenActivityId}}"
    bind:close="onHalfScreenClose"
  />
</view>
