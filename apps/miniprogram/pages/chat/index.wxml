<!--
  对话主场 (Chat-First 架构)
  Requirements: 1.1, 1.2, 1.3, 1.4, 3.2
  v3.7 重构: 使用 useChatStore，支持 UIMessage.parts 渲染
  
  三层结构：Custom_Navbar + Chat_Stream + AI_Dock
  - 首次进入显示 Widget_Dashboard
  - 空气感渐变背景
-->
<view class="chat-page {{isWelcomeState ? 'chat-page--welcome' : 'chat-page--conversation'}}">
  <!-- 网络状态通知条 -->
  <network-status
    offlineText="{{networkOfflineText}}"
    retryText="{{networkRetryText}}"
    restoredToast="{{networkRestoredToast}}"
    bind:retry="onNetworkRetry"
  />
  
  <view wx:if="{{isWelcomeState}}" class="atmospheric-bg"></view>
  
  <!-- 自定义导航栏 -->
  <custom-navbar 
    showMenu="{{true}}"
    showMore="{{true}}"
    transparent="{{isWelcomeState}}"
    bind:menutap="onNavbarMenuTap"
    bind:newchat="onNewChat"
    bind:itemtap="onNavbarItemTap"
  />

  <scroll-view wx:if="{{isWelcomeState}}" scroll-y class="welcome-layout">
    <view class="welcome-layout__inner">
      <view class="welcome-hero">
        <view class="welcome-hero__copy">
          <text class="welcome-hero__title">{{welcomeGreeting}}</text>
          <text wx:if="{{welcomeSubGreeting}}" class="welcome-hero__subtitle">{{welcomeSubGreeting}}</text>
        </view>
        <view class="welcome-hero__spark"></view>
      </view>

      <quick-prompts
        prompts="{{welcomeQuickPrompts}}"
        bind:prompttap="onWelcomePromptTap"
      />

      <view class="welcome-layout__spacer"></view>
    </view>
  </scroll-view>

  <chat-list
    wx:else
    messages="{{messages}}"
    loading="{{false}}"
  >
    <agent-task-panel
      wx:if="{{currentTasks.length > 0}}"
      tasks="{{currentTasks}}"
      bind:actiontap="onAgentTaskActionTap"
    />
    
    <view class="message-list">
      <block wx:for="{{messages}}" wx:key="id">
        <view 
          id="msg-{{item.id}}"
          class="message-item message-item--{{item.role}} {{index >= messages.length - 3 ? 'slide-up-fade-in' : ''}}"
          style="animation-delay: {{(index - (messages.length - 3)) * 50}}ms;"
        >
          <block wx:if="{{item.role === 'user'}}">
            <block wx:for="{{item.parts}}" wx:for-item="part" wx:key="index">
              <block wx:if="{{part.type === 'text'}}">
                <chat-message-shell 
                  role="user" 
                  content="{{part.text}}"
                />
              </block>
            </block>
          </block>
          
          <block wx:else>
            <block wx:for="{{item.parts}}" wx:for-item="part" wx:for-index="partIndex" wx:key="partIndex">
              <block wx:if="{{part.type === 'text'}}">
                <chat-message-shell 
                  role="assistant" 
                  content="{{part.text}}"
                  isStreaming="{{streamingMessageId === item.id}}"
                />
              </block>
              
              <block wx:elif="{{part.type === 'widget'}}">
                <chat-widget-part
                  part="{{part}}"
                  userNickname="{{userNickname}}"
                  isHistorical="{{index < messages.length - 1}}"
                  defaultErrorMessage="{{widgetErrorMessage}}"
                  defaultErrorRetryText="{{widgetErrorRetryText}}"
                  bind:dashboardactivitytap="onDashboardActivityTap"
                  bind:dashboardprompttap="onDashboardPromptTap"
                  bind:dashboardquickitemtap="onDashboardQuickItemTap"
                  bind:dashboardpreferencetap="onDashboardPreferenceTap"
                  bind:dashboardviewall="onDashboardViewAll"
                  bind:widgetactiontap="onWidgetStructuredActionTap"
                  bind:widgetsharetap="onWidgetShareTap"
                  bind:widgetshareviewdetail="onWidgetShareViewDetail"
                  bind:exploreactivitytap="onExploreActivityTap"
                  bind:exploreactiontap="onExploreActionTap"
                  bind:exploreexpandmap="onExploreExpandMap"
                  bind:partnersearchactiontap="onPartnerSearchActionTap"
                  bind:askpreferenceselect="onAskPreferenceSelect"
                  bind:askpreferenceskip="onAskPreferenceSkip"
                  bind:actionchiptap="onActionChipTap"
                  bind:partnerintentformsubmit="onPartnerIntentFormSubmit"
                  bind:draftsettingsformsubmit="onDraftSettingsFormSubmit"
                  bind:authrequiredcontinue="onAuthRequiredContinue"
                  bind:widgeterrorretry="onWidgetErrorRetry"
                />
              </block>
            </block>
          </block>
        </view>
      </block>
    </view>
    
    <view wx:if="{{status === 'submitted'}}" class="message-item message-item--assistant slide-up-fade-in">
      <chat-thinking text="稍等，我帮你看看..." />
    </view>
  </chat-list>
  
  <!-- AI Dock (超级输入坞) -->
  <chat-sender 
    id="aiDock"
    placeholder="{{composerPlaceholder}}"
    value="{{inputValue}}"
    welcome="{{isWelcomeState}}"
    bind:inputchange="onInputChange"
    bind:send="onSend"
  />
  
  <!-- 手机号绑定半屏 -->
  <auth-sheet 
    show="{{isAuthSheetVisible}}"
    bind:success="onAuthSuccess"
    bind:pendingaction="onPendingAction"
    bind:viewagreement="onAuthSheetViewAgreement"
    bind:viewpolicy="onAuthSheetViewPolicy"
  />
  
  <!-- 分享引导蒙层 -->
  <share-guide 
    show="{{isShareGuideVisible}}"
    title="{{shareGuideTitle}}"
    locationName="{{shareGuideLocationName}}"
  />
</view>
