<!--
  消息中心页面
  Requirements: 9.1, 9.2, 9.3, 9.4, 9.5
  
  - 显示所有参与的活动群聊列表
  - 显示活动标题、最后一条消息、未读数量
  - 点击跳转到 Lite_Chat 页面
-->
<view class="message-page">
  <!-- 自定义导航栏 -->
  <custom-navbar 
    title="消息中心" 
    showMenu="{{false}}" 
    showMore="{{false}}"
    showBack="{{true}}"
    bindback="goBack"
  />

  <!-- 内容区域 -->
  <scroll-view
    class="message-scroll"
    scroll-y
    enhanced
    show-scrollbar="{{false}}"
    refresher-enabled
    refresher-triggered="{{loading}}"
    bindrefresherrefresh="loadData"
  >
    <!-- 系统通知区域 -->
    <view class="section-card">
      <view 
        class="section-header"
        bind:tap="toggleNotificationExpand"
      >
        <view class="section-title">
          <view class="section-icon section-icon--amber">
            <t-icon name="notification" size="36rpx" />
          </view>
          <text>系统通知</text>
          <t-badge
            wx:if="{{unreadNotificationCount > 0}}"
            count="{{unreadNotificationCount}}"
          />
        </view>
        <t-icon
          name="{{notificationExpanded ? 'chevron-up' : 'chevron-down'}}"
          size="40rpx"
          color="#9CA3AF"
        />
      </view>

      <view wx:if="{{notificationExpanded}}" class="notification-list">
        <block wx:if="{{notifications.length > 0}}">
          <view
            wx:for="{{notifications}}"
            wx:key="id"
            class="notification-item {{item.read ? '' : 'notification-item--unread'}}"
            data-id="{{item.id}}"
            data-type="{{item.type}}"
            data-activity-id="{{item.activityId}}"
            data-source="{{item.source}}"
            data-match-id="{{item.matchId}}"
            data-is-temp-organizer="{{item.isTempOrganizer}}"
            bind:tap="onNotificationTap"
          >
            <!-- 图标 -->
            <view class="notification-icon notification-icon--{{item.type}}">
              <t-icon
                name="{{item.type === 'join' || item.type === 'new_participant' || item.type === 'match_pending' ? 'user-add' : item.type === 'completed' ? 'check-circle' : item.type === 'cancelled' ? 'close-circle' : item.type === 'post_activity' ? 'chat' : item.type === 'activity_start' || item.type === 'activity_reminder' ? 'time' : item.type === 'quit' ? 'error-circle' : 'notification'}}"
                size="40rpx"
              />
            </view>
            <!-- 内容 -->
            <view class="notification-content">
              <text class="notification-title">{{item.title}}</text>
              <text class="notification-desc">{{item.content}}</text>
              <text class="notification-time">{{item.createdAt}}</text>
            </view>
            <!-- 操作 -->
            <view
              wx:if="{{item.type === 'match_pending' && item.isTempOrganizer}}"
              class="notification-action-group"
            >
              <t-button
                size="small"
                theme="primary"
                loading="{{pendingMatchActionId === item.matchId}}"
                data-match-id="{{item.matchId}}"
                catch:tap="onMatchConfirmTap"
              >
                确认成局
              </t-button>
              <t-button
                size="small"
                variant="outline"
                loading="{{pendingMatchActionId === item.matchId}}"
                data-match-id="{{item.matchId}}"
                catch:tap="onMatchCancelTap"
              >
                暂不成局
              </t-button>
            </view>
            <view wx:elif="{{item.type === 'post_activity'}}" class="notification-tag">
              复盘 / 再约
            </view>
            <view wx:elif="{{item.type === 'match_pending' && !item.isTempOrganizer}}" class="notification-tag">
              等召集人确认
            </view>
            <view wx:else class="notification-arrow">
              <t-icon name="chevron-right" size="36rpx" color="#9CA3AF" />
            </view>
          </view>
        </block>
        <view wx:else class="empty-state">
          <text>暂无系统通知</text>
        </view>
      </view>
    </view>

    <!-- 群聊列表区域 -->
    <view class="section-card">
      <view class="section-header">
        <view class="section-title">
          <view class="section-icon section-icon--blue">
            <t-icon name="chat" size="36rpx" />
          </view>
          <text>活动群聊</text>
        </view>
      </view>

      <view class="chat-list">
        <block wx:if="{{chatList.length > 0}}">
          <view
            wx:for="{{chatList}}"
            wx:key="activityId"
            class="chat-item {{item.isArchived ? 'chat-item--archived' : ''}}"
            data-activity-id="{{item.activityId}}"
            bind:tap="onChatTap"
          >
            <!-- 头像 -->
            <view class="chat-avatar">
              <image
                src="{{item.activityImage || '/static/images/default-activity.png'}}"
                mode="aspectFill"
                class="chat-avatar__img"
              />
              <view wx:if="{{item.isArchived}}" class="chat-avatar__badge">
                <text>已归档</text>
              </view>
            </view>
            <!-- 信息 -->
            <view class="chat-content">
              <view class="chat-header">
                <text class="chat-title">{{item.activityTitle}}</text>
                <text class="chat-time">{{item.lastMessageTime}}</text>
              </view>
              <view class="chat-footer">
                <text class="chat-message">{{item.lastMessage || '暂无消息'}}</text>
                <t-badge
                  wx:if="{{item.unreadCount > 0}}"
                  count="{{item.unreadCount}}"
                />
              </view>
              <view class="chat-meta">
                <t-icon name="user" size="24rpx" />
                <text>{{item.participantCount}}人</text>
              </view>
            </view>
          </view>
        </block>
        <view wx:else class="empty-state empty-state--large">
          <t-icon name="chat" size="96rpx" color="#E5E7EB" />
          <text class="empty-title">暂无群聊</text>
          <text class="empty-desc">参与活动后即可加入群聊</text>
        </view>
      </view>
    </view>
  </scroll-view>
  <t-popup
    visible="{{showMatchDetail}}"
    placement="bottom"
    bind:visible-change="onMatchDetailVisibleChange"
  >
    <view class="match-detail-sheet" catchtouchmove="noop">
      <view class="match-detail-sheet__header">
        <view>
          <text class="match-detail-sheet__title">{{selectedMatchDetail ? '待确认搭子详情' : '搭子详情'}}</text>
          <text class="match-detail-sheet__subtitle">把当前状态、下一步和破冰建议讲清楚</text>
        </view>
        <view class="match-detail-sheet__close" bind:tap="closeMatchDetail">
          <t-icon name="close" size="36rpx" color="#9CA3AF" />
        </view>
      </view>

      <view wx:if="{{matchDetailLoading}}" class="match-detail-sheet__loading">
        <t-loading theme="circular" size="48rpx" text="正在整理匹配详情..." />
      </view>

      <view wx:elif="{{matchDetailError}}" class="match-detail-sheet__empty">
        <text class="match-detail-sheet__empty-title">详情暂时没拉下来</text>
        <text class="match-detail-sheet__empty-desc">{{matchDetailError}}</text>
        <t-button size="small" theme="primary" bind:tap="closeMatchDetail">知道了</t-button>
      </view>

      <scroll-view wx:elif="{{selectedMatchDetail}}" class="match-detail-scroll" scroll-y enhanced show-scrollbar="{{false}}">
        <view class="match-detail-card">
          <view class="match-detail-card__header">
            <view>
              <text class="match-detail-card__title">{{selectedMatchDetail.typeName}} 搭子</text>
              <text class="match-detail-card__desc">匹配度 {{selectedMatchDetail.matchScore}}%</text>
            </view>
            <view class="match-detail-badge {{selectedMatchDetail.isTempOrganizer ? 'match-detail-badge--primary' : ''}}">
              <text>{{selectedMatchDetail.isTempOrganizer ? '现在你来拍板' : '等召集人确认'}}</text>
            </view>
          </view>

          <view class="match-detail-meta">
            <view class="match-detail-pill">
              <t-icon name="location" size="28rpx" color="#5B75FB" />
              <text>{{selectedMatchDetail.locationHint}}</text>
            </view>
            <view class="match-detail-pill">
              <t-icon name="time" size="28rpx" color="#F59E0B" />
              <text>{{selectedMatchDetail.confirmDeadlineText}} 前确认</text>
            </view>
            <view class="match-detail-pill">
              <t-icon name="user" size="28rpx" color="#10B981" />
              <text>召集人：{{selectedMatchDetail.organizerDisplayName}}</text>
            </view>
          </view>

          <view wx:if="{{selectedMatchDetail.commonTags.length > 0}}" class="match-detail-tags">
            <view wx:for="{{selectedMatchDetail.commonTags}}" wx:key="*this" class="match-detail-tag">
              <text>{{item}}</text>
            </view>
          </view>
        </view>

        <view class="match-detail-section">
          <text class="match-detail-section__title">现在是什么状态</text>
          <text class="match-detail-section__text">{{selectedMatchDetail.nextActionText}}</text>
        </view>

        <view wx:if="{{selectedMatchDetail.icebreaker}}" class="match-detail-section">
          <view class="match-detail-section__head">
            <text class="match-detail-section__title">系统破冰建议</text>
            <text class="match-detail-section__time">{{selectedMatchDetail.icebreaker.createdAtText}}</text>
          </view>
          <view class="match-detail-icebreaker">
            <text>{{selectedMatchDetail.icebreaker.content}}</text>
          </view>
        </view>

        <view class="match-detail-section">
          <text class="match-detail-section__title">匹配成员</text>
          <view class="match-detail-members">
            <view wx:for="{{selectedMatchDetail.members}}" wx:key="userId" class="match-detail-member">
              <view class="match-detail-member__header">
                <view class="match-detail-member__identity">
                  <image wx:if="{{item.avatarUrl}}" src="{{item.avatarUrl}}" mode="aspectFill" class="match-detail-member__avatar" />
                  <view wx:else class="match-detail-member__avatar match-detail-member__avatar--placeholder">
                    <text>{{item.nicknameInitial}}</text>
                  </view>
                  <view>
                    <view class="match-detail-member__name-row">
                      <text class="match-detail-member__name">{{item.nickname}}</text>
                      <view wx:if="{{item.isTempOrganizer}}" class="match-detail-member__badge">
                        <text>召集人</text>
                      </view>
                    </view>
                    <text class="match-detail-member__meta">{{item.locationHint}} · {{item.timePreference}}</text>
                  </view>
                </view>
              </view>
              <text class="match-detail-member__summary">{{item.intentSummary}}</text>
              <view wx:if="{{item.tags.length > 0}}" class="match-detail-member__tags">
                <view wx:for="{{item.tags}}" wx:key="*this" class="match-detail-member__tag">
                  <text>{{item}}</text>
                </view>
              </view>
            </view>
          </view>
        </view>

        <view class="match-detail-actions">
          <t-button
            wx:if="{{selectedMatchDetail.isTempOrganizer}}"
            theme="primary"
            loading="{{pendingMatchActionId === selectedMatchDetail.id}}"
            data-match-id="{{selectedMatchDetail.id}}"
            catch:tap="onMatchConfirmTap"
          >
            确认成局
          </t-button>
          <t-button
            wx:if="{{selectedMatchDetail.isTempOrganizer}}"
            variant="outline"
            loading="{{pendingMatchActionId === selectedMatchDetail.id}}"
            data-match-id="{{selectedMatchDetail.id}}"
            catch:tap="onMatchCancelTap"
          >
            暂不成局
          </t-button>
          <t-button wx:if="{{!selectedMatchDetail.isTempOrganizer}}" variant="outline" bind:tap="closeMatchDetail">
            我知道了
          </t-button>
        </view>
      </scroll-view>
    </view>
  </t-popup>
</view>
