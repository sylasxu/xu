{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://juchang.dev/schemas/genui/request.schema.json",
  "title": "GenUIRequest",
  "type": "object",
  "required": ["input"],
  "properties": {
    "conversationId": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "text"],
          "properties": {
            "type": { "const": "text" },
            "text": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["type", "action", "actionId"],
          "properties": {
            "type": { "const": "action" },
            "action": { "type": "string", "minLength": 1 },
            "actionId": { "type": "string", "minLength": 1 },
            "displayText": { "type": "string" },
            "params": { "type": "object" }
          },
          "additionalProperties": true
        }
      ]
    },
    "context": {
      "type": "object",
      "properties": {
        "client": {
          "type": "string",
          "enum": ["web", "miniprogram", "admin"]
        },
        "locale": { "type": "string" },
        "timezone": { "type": "string" },
        "platformVersion": { "type": "string" },
        "lat": { "type": "number" },
        "lng": { "type": "number" },
        "activityId": { "type": "string", "minLength": 1 },
        "followUpMode": {
          "type": "string",
          "enum": ["review", "rebook", "kickoff"]
        },
        "entry": { "type": "string" },
        "transientTurns": {
          "type": "array",
          "maxItems": 12,
          "items": {
            "type": "object",
            "required": ["role", "text"],
            "properties": {
              "role": {
                "type": "string",
                "enum": ["user", "assistant"]
              },
              "text": {
                "type": "string",
                "minLength": 1
              },
              "primaryBlockType": {
                "type": ["string", "null"],
                "enum": ["text", "choice", "entity-card", "list", "form", "cta-group", "alert", null]
              },
              "turnContext": {
                "$ref": "#/definitions/turnContext"
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "ai": {
      "type": "object",
      "properties": {
        "model": {
          "type": "string",
          "minLength": 1
        },
        "temperature": {
          "type": "number",
          "minimum": 0,
          "maximum": 2
        },
        "maxTokens": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "turnContextChoiceOption": {
      "type": "object",
      "required": ["label", "action"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "turnContextListItem": {
      "type": "object",
      "required": ["title", "action"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "aliases": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "turnContextCtaItem": {
      "type": "object",
      "required": ["label", "action"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      },
      "additionalProperties": false
    },
    "turnContext": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "options"],
          "properties": {
            "kind": { "const": "choice" },
            "question": { "type": "string" },
            "options": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": { "$ref": "#/definitions/turnContextChoiceOption" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": { "const": "list" },
            "title": { "type": "string" },
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": { "$ref": "#/definitions/turnContextListItem" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": { "const": "cta-group" },
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": { "$ref": "#/definitions/turnContextCtaItem" }
            }
          },
          "additionalProperties": false
        }
      ]
    }
  },
  "additionalProperties": false
}
