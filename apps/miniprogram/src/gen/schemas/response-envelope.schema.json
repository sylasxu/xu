{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://xu.example/schemas/genui/response-envelope.schema.json",
  "title": "GenUIResponseEnvelope",
  "type": "object",
  "required": ["traceId", "conversationId", "response"],
  "properties": {
    "traceId": { "type": "string", "minLength": 1 },
    "conversationId": { "type": "string", "minLength": 1 },
    "response": {
      "type": "object",
      "required": ["responseId", "role", "status", "blocks"],
      "properties": {
        "responseId": { "type": "string", "minLength": 1 },
        "role": { "const": "assistant" },
        "status": {
          "type": "string",
          "enum": ["streaming", "completed", "error"]
        },
        "blocks": {
          "type": "array",
          "items": { "$ref": "#/definitions/block" }
        },
        "suggestions": {
          "$ref": "#/definitions/suggestions"
        }
      },
      "additionalProperties": false
    }
  },
  "definitions": {
    "suggestionsChoiceOption": {
      "type": "object",
      "required": ["label", "action"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "value": { "type": "string" }
      },
      "additionalProperties": false
    },
    "suggestionsListItem": {
      "type": "object",
      "required": ["title", "action"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "params": { "type": "object" },
        "aliases": {
          "type": "array",
          "maxItems": 8,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "suggestionsCtaItem": {
      "type": "object",
      "required": ["label", "action"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "params": { "type": "object" }
      },
      "additionalProperties": false
    },
    "suggestions": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "options"],
          "properties": {
            "kind": { "const": "choice" },
            "question": { "type": "string" },
            "options": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": { "$ref": "#/definitions/suggestionsChoiceOption" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": { "const": "list" },
            "title": { "type": "string" },
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": { "$ref": "#/definitions/suggestionsListItem" }
            }
          },
          "additionalProperties": false
        },
        {
          "type": "object",
          "required": ["kind", "items"],
          "properties": {
            "kind": { "const": "cta-group" },
            "items": {
              "type": "array",
              "minItems": 1,
              "maxItems": 12,
              "items": { "$ref": "#/definitions/suggestionsCtaItem" }
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "block": {
      "oneOf": [
        { "$ref": "#/definitions/textBlock" },
        { "$ref": "#/definitions/choiceBlock" },
        { "$ref": "#/definitions/entityCardBlock" },
        { "$ref": "#/definitions/listBlock" },
        { "$ref": "#/definitions/formBlock" },
        { "$ref": "#/definitions/ctaGroupBlock" },
        { "$ref": "#/definitions/alertBlock" }
      ]
    },
    "blockBase": {
      "type": "object",
      "required": ["blockId", "type"],
      "properties": {
        "blockId": { "type": "string", "minLength": 1 },
        "type": { "type": "string" },
        "dedupeKey": { "type": "string" },
        "replacePolicy": {
          "type": "string",
          "enum": ["append", "replace", "ignore-if-exists"]
        },
        "meta": { "type": "object" }
      },
      "additionalProperties": true
    },
    "textBlock": {
      "allOf": [
        { "$ref": "#/definitions/blockBase" },
        {
          "type": "object",
          "required": ["type", "content"],
          "properties": {
            "type": { "const": "text" },
            "content": { "type": "string" }
          }
        }
      ]
    },
    "choiceBlock": {
      "allOf": [
        { "$ref": "#/definitions/blockBase" },
        {
          "type": "object",
          "required": ["type", "question", "options"],
          "properties": {
            "type": { "const": "choice" },
            "question": { "type": "string" },
            "options": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["label", "action"],
                "properties": {
                  "label": { "type": "string" },
                  "action": { "type": "string" },
                  "params": { "type": "object" }
                },
                "additionalProperties": true
              }
            }
          }
        }
      ]
    },
    "entityCardBlock": {
      "allOf": [
        { "$ref": "#/definitions/blockBase" },
        {
          "type": "object",
          "required": ["type", "title", "fields"],
          "properties": {
            "type": { "const": "entity-card" },
            "title": { "type": "string" },
            "fields": { "type": "object" }
          }
        }
      ]
    },
    "listBlock": {
      "allOf": [
        { "$ref": "#/definitions/blockBase" },
        {
          "type": "object",
          "required": ["type", "items"],
          "properties": {
            "type": { "const": "list" },
            "title": { "type": "string" },
            "center": {
              "type": "object",
              "required": ["lat", "lng", "name"],
              "properties": {
                "lat": { "type": "number" },
                "lng": { "type": "number" },
                "name": { "type": "string" }
              },
              "additionalProperties": true
            },
            "semanticQuery": { "type": "string" },
            "fetchConfig": { "type": "object" },
            "interaction": { "type": "object" },
            "preview": { "type": "object" },
            "items": {
              "type": "array",
              "items": { "type": "object" }
            }
          }
        }
      ]
    },
    "formBlock": {
      "allOf": [
        { "$ref": "#/definitions/blockBase" },
        {
          "type": "object",
          "required": ["type", "schema"],
          "properties": {
            "type": { "const": "form" },
            "title": { "type": "string" },
            "schema": { "type": "object" },
            "initialValues": { "type": "object" }
          }
        }
      ]
    },
    "ctaGroupBlock": {
      "allOf": [
        { "$ref": "#/definitions/blockBase" },
        {
          "type": "object",
          "required": ["type", "items"],
          "properties": {
            "type": { "const": "cta-group" },
            "items": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["label", "action"],
                "properties": {
                  "label": { "type": "string" },
                  "action": { "type": "string" },
                  "params": { "type": "object" }
                },
                "additionalProperties": true
              }
            }
          }
        }
      ]
    },
    "alertBlock": {
      "allOf": [
        { "$ref": "#/definitions/blockBase" },
        {
          "type": "object",
          "required": ["type", "level", "message"],
          "properties": {
            "type": { "const": "alert" },
            "level": {
              "type": "string",
              "enum": ["info", "warning", "error", "success"]
            },
            "message": { "type": "string" }
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
