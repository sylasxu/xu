<!--
  履约确认页面
  TDesign + Atomic Less 重构
-->
<view class="activity-confirm-page pb-bottom-bar">
  <!-- 导航栏 -->
  <t-navbar title="履约确认" left-arrow />

  <!-- 加载状态 -->
  <view class="activity-confirm-page__loading" wx:if="{{loading}}">
    <t-loading theme="circular" size="80rpx" />
    <text>加载中...</text>
  </view>

  <block wx:else>
    <!-- 活动信息头部 -->
    <view class="activity-confirm-page__card" wx:if="{{activity}}">
      <view class="activity-confirm-page__title">{{activity.title}}</view>
      <view class="activity-confirm-page__meta">
        <view class="activity-confirm-page__meta-row">
          <t-icon name="time" size="32rpx" />
          <text>{{activity.startAt}}</text>
        </view>
        <view class="activity-confirm-page__meta-row">
          <t-icon name="location" size="32rpx" />
          <text>{{activity.locationName}}</text>
        </view>
      </view>
    </view>

    <!-- 提示信息 -->
    <view class="tips-section activity-confirm-page__tips">
      <t-icon name="info-circle-filled" size="40rpx" color="#FF9500" class="activity-confirm-page__tips-icon" />
      <view class="activity-confirm-page__tips-content">
        <text class="activity-confirm-page__tips-title">请确认参与者的到场情况</text>
        <text class="activity-confirm-page__tips-hint">默认全部已到场，如有未到场请取消勾选</text>
      </view>
    </view>

    <!-- 参与者列表 -->
    <view class="activity-confirm-page__panel">
      <view class="activity-confirm-page__panel-header">
        <text class="activity-confirm-page__panel-title">参与者列表 ({{participants.length}}人)</text>
        <view class="select-all-btn activity-confirm-page__select-all" bind:tap="onSelectAll">
          <text>全选已到场</text>
        </view>
      </view>

      <view>
        <view
          wx:for="{{participants}}"
          wx:key="id"
          class="participant-item activity-confirm-page__participant {{item.fulfilled ? '' : 'no-show'}}"
          data-index="{{index}}"
          bind:tap="onToggleFulfilled"
        >
          <view class="activity-confirm-page__participant-check">
            <t-checkbox checked="{{item.fulfilled}}" icon="circle" borderless />
          </view>
          <image
            class="activity-confirm-page__participant-avatar"
            src="{{item.avatarUrl || '/static/images/default-avatar.png'}}"
            mode="aspectFill"
          />
          <view class="activity-confirm-page__participant-main">
            <view class="activity-confirm-page__participant-name">
              <text>{{item.nickname}}</text>
            </view>
          </view>
          <view class="activity-confirm-page__participant-status {{item.fulfilled ? 'status-fulfilled' : 'status-no-show'}}">
            <text>{{item.fulfilled ? '已到场' : '未到场'}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 未到场统计 -->
    <view class="no-show-summary activity-confirm-page__summary" wx:if="{{noShowCount > 0}}">
      <t-icon name="error-circle" size="40rpx" color="#FF4D4F" />
      <text>您标记了 {{noShowCount}} 人未到场</text>
    </view>

    <!-- 底部操作栏 -->
    <view class="bottom-bar activity-confirm-page__footer">
      <view class="activity-confirm-page__warning" wx:if="{{noShowCount > 0}}">
        <t-icon name="info-circle" size="28rpx" />
        <text>请确认未到场名单后再提交</text>
      </view>
      <t-button
        theme="primary"
        size="large"
        block
        loading="{{submitting}}"
        bind:tap="onSubmit"
      >
        确认提交
      </t-button>
      <view class="safe-bottom"></view>
    </view>
  </block>

  <!-- 警告弹窗 -->
  <t-dialog
    visible="{{showWarningDialog}}"
    title="标记未到场"
    content="确定要将 {{currentParticipant.nickname}} 标记为未到场吗？"
    confirm-btn="确定标记"
    cancel-btn="取消"
    bind:confirm="onConfirmNoShow"
    bind:cancel="onCancelNoShow"
  />
</view>
