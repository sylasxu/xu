<!--
  创建活动页面
  TDesign + Atomic Less 重构
-->
<wxs module="utils">
  function getTypeLabel(value, types) {
    if (!value || !types) return '请选择';
    for (var i = 0; i < types.length; i++) {
      if (types[i].value === value) return types[i].label;
    }
    return '请选择';
  }
  
  function formatDateTime(dateStr) {
    if (!dateStr) return '请选择';
    var date = getDate(dateStr);
    var month = date.getMonth() + 1;
    var day = date.getDate();
    var hours = date.getHours();
    var minutes = date.getMinutes();
    var hoursStr = hours < 10 ? '0' + hours : '' + hours;
    var minutesStr = minutes < 10 ? '0' + minutes : '' + minutes;
    return month + '月' + day + '日 ' + hoursStr + ':' + minutesStr;
  }
  
  module.exports = {
    getTypeLabel: getTypeLabel,
    formatDateTime: formatDateTime
  };
</wxs>

<view class="activity-create-page">
  <scroll-view scroll-y class="form-scroll activity-create-page__scroll">
    <!-- 基本信息 -->
    <view class="activity-create-page__section">
      <view class="activity-create-page__section-title">
        基本信息
      </view>
      
      <!-- 活动标题 -->
      <view class="activity-create-page__field">
        <view class="activity-create-page__label required">活动标题</view>
        <t-input
          placeholder="请输入活动标题（最多100字）"
          value="{{form.title}}"
          maxlength="{{100}}"
          bindinput="onTitleInput"
        />
      </view>
      
      <!-- 活动类型 -->
      <view class="activity-create-page__field" bindtap="showTypePicker">
        <view class="activity-create-page__label required">活动类型</view>
        <view class="activity-create-page__picker">
          <text class="{{form.type ? 'activity-create-page__picker-text' : 'placeholder'}}">
            {{utils.getTypeLabel(form.type, activityTypes)}}
          </text>
          <t-icon name="chevron-right" size="40rpx" color="#D1D5DB" />
        </view>
      </view>
      
      <!-- 活动描述 -->
      <view class="activity-create-page__field">
        <view class="activity-create-page__label">活动描述</view>
        <t-textarea
          placeholder="介绍一下你的活动吧~"
          value="{{form.description}}"
          maxlength="{{500}}"
          autosize
          bindinput="onDescriptionInput"
        />
      </view>
      
      <!-- 活动图片 -->
      <view>
        <view class="activity-create-page__label">活动图片</view>
        <t-upload
          media-type="{{['image']}}"
          max="{{maxImageCount}}"
          files="{{form.images}}"
          bind:success="onImageSuccess"
          bind:remove="onImageRemove"
        />
      </view>
    </view>
    
    <!-- 时间地点 -->
    <view class="activity-create-page__section">
      <view class="activity-create-page__section-title">
        时间地点
      </view>
      
      <!-- 开始时间 -->
      <view class="activity-create-page__field" bindtap="showStartTimePicker">
        <view class="activity-create-page__label required">开始时间</view>
        <view class="activity-create-page__picker">
          <text class="{{form.startAt ? 'activity-create-page__picker-text' : 'placeholder'}}">
            {{utils.formatDateTime(form.startAt)}}
          </text>
          <t-icon name="chevron-right" size="40rpx" color="#D1D5DB" />
        </view>
      </view>
      
      <!-- 结束时间 -->
      <view class="activity-create-page__field" bindtap="showEndTimePicker">
        <view class="activity-create-page__label">结束时间</view>
        <view class="activity-create-page__picker">
          <text class="{{form.endAt ? 'activity-create-page__picker-text' : 'placeholder'}}">
            {{utils.formatDateTime(form.endAt)}}
          </text>
          <t-icon name="chevron-right" size="40rpx" color="#D1D5DB" />
        </view>
      </view>
      
      <!-- 活动地点 -->
      <view class="activity-create-page__field" bindtap="onChooseLocation">
        <view class="activity-create-page__label required">活动地点</view>
        <view class="activity-create-page__picker">
          <text class="{{form.locationName ? 'activity-create-page__picker-text' : 'placeholder'}}">
            {{form.locationName || '请选择地点'}}
          </text>
          <t-icon name="location" size="40rpx" color="#FF6B35" />
        </view>
      </view>
      
      <!-- 详细地址显示 -->
      <view wx:if="{{form.address}}" class="activity-create-page__address">
        <t-icon name="location" size="32rpx" color="#9CA3AF" />
        <text class="activity-create-page__address-text">{{form.address}}</text>
      </view>
      
      <!-- 位置备注 -->
      <view wx:if="{{form.latitude}}" class="activity-create-page__field">
        <view class="activity-create-page__label required">位置备注</view>
        <t-input
          placeholder="如：4楼平台入口、星巴克门口"
          value="{{form.locationHint}}"
          maxlength="{{50}}"
          bindinput="onLocationHintInput"
        />
        <view class="activity-create-page__helper">帮助参与者更容易找到你</view>
      </view>
      
    </view>
    
    <!-- 活动设置 -->
    <view class="activity-create-page__section">
      <view class="activity-create-page__section-title">
        活动设置
      </view>
      
      <!-- 参与人数 -->
      <view class="activity-create-page__participants">
        <view class="activity-create-page__label required">参与人数</view>
        <t-stepper
          value="{{form.maxParticipants}}"
          min="{{2}}"
          max="{{100}}"
          theme="filled"
          bind:change="onParticipantsChange"
        />
      </view>
    </view>
    
    <!-- 底部占位 -->
    <view class="bottom-placeholder"></view>
  </scroll-view>
  
  <!-- 底部提交栏 -->
  <view class="bottom-bar activity-create-page__footer">
    <t-button
      theme="primary"
      size="large"
      block
      loading="{{isSubmitting}}"
      disabled="{{isSubmitting}}"
      bindtap="onSubmit"
    >
      {{isSubmitting ? '发布中...' : '发布活动'}}
    </t-button>
  </view>
  
  <!-- 选择器组件 -->
  <t-picker
    visible="{{showTypePicker}}"
    value="{{[form.type]}}"
    title="选择活动类型"
    cancelBtn="取消"
    confirmBtn="确定"
    bind:change="onTypeChange"
    bind:cancel="onTypePickerCancel"
  >
    <t-picker-item options="{{activityTypes}}" />
  </t-picker>
  
  <t-date-time-picker
    visible="{{showStartTimePicker}}"
    mode="minute"
    value="{{form.startAt}}"
    title="选择开始时间"
    cancelBtn="取消"
    confirmBtn="确定"
    start="{{Date.now()}}"
    bind:change="onStartTimeChange"
    bind:cancel="onStartTimePickerCancel"
  />
  
  <t-date-time-picker
    visible="{{showEndTimePicker}}"
    mode="minute"
    value="{{form.endAt || form.startAt}}"
    title="选择结束时间"
    cancelBtn="取消"
    confirmBtn="确定"
    start="{{form.startAt || Date.now()}}"
    bind:change="onEndTimeChange"
    bind:cancel="onEndTimePickerCancel"
  />
</view>
