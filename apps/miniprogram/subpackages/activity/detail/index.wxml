<!--
  活动详情页
  TDesign + Atomic Less 重构
-->
<wxs module="utils">
  function formatTime(dateStr) {
    if (!dateStr) return '';
    var date = getDate(dateStr);
    var hours = date.getHours();
    var minutes = date.getMinutes();
    var timeStr = (hours < 10 ? '0' + hours : hours) + ':' + (minutes < 10 ? '0' + minutes : minutes);
    var month = date.getMonth() + 1;
    var day = date.getDate();
    var weekDays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
    var weekDay = weekDays[date.getDay()];
    return month + '月' + day + '日 ' + weekDay + ' ' + timeStr;
  }
  
  function getActivityTypeText(type) {
    var map = { food: '美食', entertainment: '娱乐', sports: '运动', boardgame: '桌游', other: '其他' };
    return map[type] || type || '';
  }
  
  function getStatusText(status) {
    var map = {
      creator: '我发起的',
      joined: '已加入',
      waitlisted: '候补中',
      waitlist: '候补中',
      quit: '已退出',
      closed: '已停止加入'
    };
    return map[status] || '';
  }
  
  function getDisplayAddress(activity) {
    if (!activity) return '';
    return activity.address || activity.locationName || activity.locationHint || '';
  }
  
  module.exports = {
    formatTime: formatTime,
    getActivityTypeText: getActivityTypeText,
    getStatusText: getStatusText,
    getDisplayAddress: getDisplayAddress
  };
</wxs>

<view class="activity-detail-page pb-bottom-bar">
  <!-- 自定义导航栏 -->
  <custom-navbar 
    title="活动详情" 
    showMenu="{{false}}" 
    showMore="{{false}}"
    showBack="{{true}}"
    transparent="{{!loading && !error}}"
  />

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="activity-detail-page__state">
    <t-loading theme="circular" size="80rpx" />
    <text class="activity-detail-page__state-text">加载中...</text>
  </view>
  
  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="activity-detail-page__state">
    <t-icon name="error-circle" size="120rpx" color="#FF4D4F" />
    <text class="activity-detail-page__error-text">{{errorMsg || '加载失败'}}</text>
    <t-button theme="primary" size="small" bindtap="onRefresh">重试</t-button>
  </view>
  
  <!-- 活动内容 -->
  <view wx:else>
    <!-- 活动图片轮播 -->
    <view class="activity-detail-page__hero">
      <swiper wx:if="{{activity.images && activity.images.length > 0}}" 
              class="activity-detail-page__hero-swiper" 
              indicator-dots="{{activity.images.length > 1}}"
              autoplay="{{false}}">
        <swiper-item wx:for="{{activity.images}}" wx:key="index">
          <image src="{{item}}" mode="aspectFill" class="activity-detail-page__hero-image" />
        </swiper-item>
      </swiper>
      <view wx:else class="activity-detail-page__hero-empty">
        <t-icon name="image" size="80rpx" color="#D1D5DB" />
        <text class="activity-detail-page__hero-empty-text">暂无图片</text>
      </view>
      
    </view>
    
    <!-- 活动基本信息 -->
    <view class="activity-detail-page__card">
      <!-- 标题和类型 -->
      <view class="activity-detail-page__header">
        <text class="activity-detail-page__title">{{activity.title}}</text>
        <t-tag wx:if="{{activity.type}}" size="small" variant="light" theme="primary">
          {{utils.getActivityTypeText(activity.type)}}
        </t-tag>
      </view>
      
      <!-- 活动状态 -->
      <view wx:if="{{joinState}}" class="activity-detail-page__status-row">
        <t-tag size="small" variant="light" 
               theme="{{joinState === 'joined' ? 'success' : joinState === 'waitlisted' ? 'warning' : 'default'}}">
          {{utils.getStatusText(joinState)}}
        </t-tag>
        <text wx:if="{{isCreator}}" class="activity-detail-page__creator-badge">我发起的</text>
      </view>
      
      <!-- 时间 -->
      <view class="info-row activity-detail-page__info-row">
        <t-icon name="time" size="36rpx" color="#FF6B35" />
        <view class="activity-detail-page__info-content">
          <text class="activity-detail-page__info-label">活动时间</text>
          <text class="activity-detail-page__info-value">{{utils.formatTime(activity.startAt)}}</text>
          <text wx:if="{{activity.endAt}}" class="activity-detail-page__info-hint">至 {{utils.formatTime(activity.endAt)}}</text>
        </view>
      </view>
      
      <!-- 地点 -->
      <view class="info-row activity-detail-page__info-row">
        <t-icon name="location" size="36rpx" color="#FF6B35" />
        <view class="activity-detail-page__info-content">
          <text class="activity-detail-page__info-label">活动地点</text>
          <text class="activity-detail-page__info-value">{{utils.getDisplayAddress(activity)}}</text>
          <text wx:if="{{activity.locationHint}}" class="activity-detail-page__info-brand">{{activity.locationHint}}</text>
        </view>
      </view>
      
      <!-- 人数 -->
      <view class="info-row activity-detail-page__info-row">
        <t-icon name="user" size="36rpx" color="#FF6B35" />
        <view class="activity-detail-page__info-content">
          <text class="activity-detail-page__info-label">参与人数</text>
          <text class="activity-detail-page__info-value">
            {{activity.currentParticipants || 0}}/{{activity.maxParticipants}}人
            <text wx:if="{{isHotActivity}}" class="activity-detail-page__hot-tag">🔥热门</text>
          </text>
          <text wx:if="{{activity.isFull}}" class="activity-detail-page__info-warning">当前已满员，可先候补排队</text>
          <text wx:elif="{{activity.remainingSeats >= 0}}" class="activity-detail-page__info-muted">还剩 {{activity.remainingSeats}} 个位置</text>
        </view>
      </view>

      <view wx:if="{{activity.conversionTips && activity.conversionTips.joinContext}}" class="activity-detail-page__conversion-note">
        <text class="activity-detail-page__conversion-text">{{activity.conversionTips.joinContext}}</text>
      </view>
      
    </view>
    
    <!-- 活动描述 -->
    <view wx:if="{{activity.description}}" class="activity-detail-page__card">
      <text class="activity-detail-page__section-title">活动详情</text>
      <text class="activity-detail-page__description">{{activity.description}}</text>
    </view>

    <!-- 快捷操作 -->
    <view class="activity-detail-page__card">
      <text class="activity-detail-page__section-title">快捷操作</text>
      <view class="activity-detail-page__quick-actions">
        <button class="activity-detail-page__quick-btn activity-detail-page__quick-btn--secondary" bindtap="onCopyActivityText">
          📋 复制文案
        </button>
        <button class="activity-detail-page__quick-btn activity-detail-page__quick-btn--brand" bindtap="onCloneActivity">
          👯‍♂️ 找类似的局
        </button>
      </view>
      <text wx:if="{{activity.conversionTips && activity.conversionTips.cloneContext}}" class="activity-detail-page__quick-hint">
        {{activity.conversionTips.cloneContext}}
      </text>
    </view>
    
    <!-- 发起人信息 -->
    <view class="activity-detail-page__card" bindtap="onCreatorTap">
      <text class="activity-detail-page__section-title">发起人</text>
      <view class="creator-card activity-detail-page__creator-card">
        <t-avatar image="{{activity.creator.avatarUrl}}" size="96rpx" icon="user" />
        <view class="activity-detail-page__creator-main">
          <text class="activity-detail-page__creator-name">{{activity.creator.nickname || '匿名用户'}}</text>
      </view>
        <t-icon name="chevron-right" size="32rpx" color="#D1D5DB" />
      </view>
    </view>
    
    <!-- 参与者列表 -->
    <view wx:if="{{(isCreator || joinState === 'joined') && activity.participants && activity.participants.length > 0}}" 
          class="activity-detail-page__card">
      <text class="activity-detail-page__section-title">参与者 ({{activity.participants.length}})</text>
      <view class="activity-detail-page__participants">
        <view wx:for="{{activity.participants}}" wx:key="id" class="participant-item activity-detail-page__participant-item">
          <t-avatar image="{{item.user.avatarUrl}}" size="64rpx" icon="user" />
          <view class="activity-detail-page__participant-main">
            <text class="activity-detail-page__participant-name">{{item.user.nickname || '匿名用户'}}</text>
            <t-tag size="small" variant="light"
                   theme="{{item.status === 'joined' ? 'success' : item.status === 'waitlist' ? 'warning' : 'default'}}">
              {{utils.getStatusText(item.status)}}
            </t-tag>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 讨论区预览 -->
    <view wx:if="{{recentMessages.length > 0}}" class="activity-detail-page__card">
      <view class="activity-detail-page__discussion-header">
        <text class="activity-detail-page__section-title activity-detail-page__section-title--tight">讨论区</text>
        <view class="activity-detail-page__discussion-link" bindtap="onEnterChat">
          <text class="activity-detail-page__discussion-link-text">查看更多</text>
          <t-icon name="chevron-right" size="32rpx" color="#5B75FB" />
        </view>
      </view>
      <view wx:for="{{recentMessages}}" wx:key="index" class="discussion-msg-item activity-detail-page__discussion-item {{index < recentMessages.length - 1 ? 'activity-detail-page__discussion-item--spaced' : ''}}">
        <image class="discussion-msg-avatar activity-detail-page__discussion-avatar" src="{{item.senderAvatar}}" mode="aspectFill" />
        <view class="activity-detail-page__discussion-main">
          <text class="activity-detail-page__discussion-nickname">{{item.senderNickname}}</text>
          <text class="activity-detail-page__discussion-content">{{item.content}}</text>
        </view>
      </view>
    </view>
    
    <!-- 底部操作栏 -->
    <view class="bottom-bar activity-detail-page__bottom-bar">
      <button class="share-btn activity-detail-page__icon-action" open-type="share">
        <t-icon name="share" size="40rpx" />
        <text>分享</text>
      </button>
      
      <button wx:if="{{isCreator || joinState === 'joined'}}" 
              class="chat-btn activity-detail-page__icon-action activity-detail-page__icon-action--spaced" 
              bindtap="onEnterChat">
        <t-icon name="chat" size="40rpx" />
        <text>讨论区</text>
      </button>
      
      <!-- 举报入口（非创建者可见） -->
      <button wx:if="{{!isCreator}}" 
              class="report-btn activity-detail-page__icon-action activity-detail-page__icon-action--spaced" 
              bindtap="onReportTap">
        <t-icon name="flag" size="40rpx" />
        <text>举报</text>
      </button>
      
      <button wx:if="{{!isCreator && activity.canJoin}}" 
              class="join-btn activity-detail-page__primary-action" 
              bindtap="onJoinTap">
        {{activity.isFull ? '候补排队' : '我要报名'}}
      </button>
      
      <view wx:elif="{{joinState && !isCreator}}" 
            class="activity-detail-page__primary-action activity-detail-page__primary-action--disabled">
        <text>{{utils.getStatusText(joinState)}}</text>
      </view>
      
      <view wx:elif="{{isCreator}}" class="activity-detail-page__primary-wrapper">
        <button class="manage-btn activity-detail-page__primary-action" bindtap="onManageActivity">管理活动</button>
      </view>
    </view>
  </view>
  
  <!-- 活动管理操作面板 -->
  <t-action-sheet
    visible="{{showManageSheet}}"
    items="{{manageActions}}"
    bind:selected="onManageActionSelect"
    bind:cancel="onManageSheetClose"
    bind:close="onManageSheetClose"
  />
  
  <!-- 手机号绑定半屏 -->
  <auth-sheet 
    visible="{{isAuthSheetVisible}}" 
    bind:success="onAuthSuccess"
    bind:pendingaction="onPendingAction"
    bind:close="onAuthClose"
    bind:viewagreement="onAuthSheetViewAgreement"
    bind:viewpolicy="onAuthSheetViewPolicy"
  />
  
  <!-- 举报弹窗 -->
  <report-sheet
    visible="{{showReportSheet}}"
    type="activity"
    targetId="{{activityId}}"
    bind:close="onReportClose"
    bind:success="onReportSuccess"
  />
</view>
