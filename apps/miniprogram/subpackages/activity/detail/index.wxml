<!--
  活动详情页
  TDesign + Atomic Less 重构
-->
<wxs module="utils">
  function formatTime(dateStr) {
    if (!dateStr) return '';
    var date = getDate(dateStr);
    var hours = date.getHours();
    var minutes = date.getMinutes();
    var timeStr = (hours < 10 ? '0' + hours : hours) + ':' + (minutes < 10 ? '0' + minutes : minutes);
    var month = date.getMonth() + 1;
    var day = date.getDate();
    var weekDays = ['周日', '周一', '周二', '周三', '周四', '周五', '周六'];
    var weekDay = weekDays[date.getDay()];
    return month + '月' + day + '日 ' + weekDay + ' ' + timeStr;
  }
  
  function getActivityTypeText(type) {
    var map = { food: '美食', entertainment: '娱乐', sports: '运动', boardgame: '桌游', other: '其他' };
    return map[type] || type || '';
  }
  
  function getStatusText(status) {
    var map = {
      creator: '我发起的',
      joined: '已加入',
      waitlisted: '候补中',
      waitlist: '候补中',
      quit: '已退出',
      closed: '已停止加入'
    };
    return map[status] || '';
  }
  
  function getDisplayAddress(activity) {
    if (!activity) return '';
    return activity.address || activity.locationName || activity.locationHint || '';
  }
  
  module.exports = {
    formatTime: formatTime,
    getActivityTypeText: getActivityTypeText,
    getStatusText: getStatusText,
    getDisplayAddress: getDisplayAddress
  };
</wxs>

<view class="min-h-screen bg-gray-50 pb-bottom-bar">
  <!-- 自定义导航栏 -->
  <custom-navbar 
    title="活动详情" 
    showMenu="{{false}}" 
    showMore="{{false}}"
    showBack="{{true}}"
    transparent="{{!loading && !error}}"
  />

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="flex flex-col items-center justify-center min-h-screen py-5">
    <t-loading theme="circular" size="80rpx" />
    <text class="mt-3 text-sm text-gray-400">加载中...</text>
  </view>
  
  <!-- 错误状态 -->
  <view wx:elif="{{error}}" class="flex flex-col items-center justify-center min-h-screen py-5">
    <t-icon name="error-circle" size="120rpx" color="#FF4D4F" />
    <text class="mt-3 mb-4 text-sm text-gray-400">{{errorMsg || '加载失败'}}</text>
    <t-button theme="primary" size="small" bindtap="onRefresh">重试</t-button>
  </view>
  
  <!-- 活动内容 -->
  <view wx:else>
    <!-- 活动图片轮播 -->
    <view class="relative w-full h-480 bg-gray-100">
      <swiper wx:if="{{activity.images && activity.images.length > 0}}" 
              class="w-full h-full" 
              indicator-dots="{{activity.images.length > 1}}"
              autoplay="{{false}}">
        <swiper-item wx:for="{{activity.images}}" wx:key="index">
          <image src="{{item}}" mode="aspectFill" class="w-full h-full" />
        </swiper-item>
      </swiper>
      <view wx:else class="flex flex-col items-center justify-center w-full h-full bg-gray-100">
        <t-icon name="image" size="80rpx" color="#D1D5DB" />
        <text class="mt-2 text-sm text-gray-300">暂无图片</text>
      </view>
      
    </view>
    
    <!-- 活动基本信息 -->
    <view class="bg-white p-4 mb-2">
      <!-- 标题和类型 -->
      <view class="flex items-start justify-between mb-3">
        <text class="flex-1 text-xl font-semibold text-gray-900 leading-relaxed mr-2">{{activity.title}}</text>
        <t-tag wx:if="{{activity.type}}" size="small" variant="light" theme="primary">
          {{utils.getActivityTypeText(activity.type)}}
        </t-tag>
      </view>
      
      <!-- 活动状态 -->
      <view wx:if="{{joinState}}" class="flex items-center gap-2 mb-3">
        <t-tag size="small" variant="light" 
               theme="{{joinState === 'joined' ? 'success' : joinState === 'waitlisted' ? 'warning' : 'default'}}">
          {{utils.getStatusText(joinState)}}
        </t-tag>
        <text wx:if="{{isCreator}}" class="text-xs text-brand bg-brand-light px-2 py-1 rounded-sm">我发起的</text>
      </view>
      
      <!-- 时间 -->
      <view class="info-row flex items-start py-3">
        <t-icon name="time" size="36rpx" color="#FF6B35" />
        <view class="flex-1 ml-3">
          <text class="block text-xs text-gray-400 mb-1">活动时间</text>
          <text class="block text-base font-medium text-gray-900">{{utils.formatTime(activity.startAt)}}</text>
          <text wx:if="{{activity.endAt}}" class="block text-sm text-gray-600 mt-1">至 {{utils.formatTime(activity.endAt)}}</text>
        </view>
      </view>
      
      <!-- 地点 -->
      <view class="info-row flex items-start py-3">
        <t-icon name="location" size="36rpx" color="#FF6B35" />
        <view class="flex-1 ml-3">
          <text class="block text-xs text-gray-400 mb-1">活动地点</text>
          <text class="block text-base font-medium text-gray-900">{{utils.getDisplayAddress(activity)}}</text>
          <text wx:if="{{activity.locationHint}}" class="block text-xs text-brand mt-1">{{activity.locationHint}}</text>
        </view>
      </view>
      
      <!-- 人数 -->
      <view class="info-row flex items-start py-3">
        <t-icon name="user" size="36rpx" color="#FF6B35" />
        <view class="flex-1 ml-3">
          <text class="block text-xs text-gray-400 mb-1">参与人数</text>
          <text class="block text-base font-medium text-gray-900">
            {{activity.currentParticipants || 0}}/{{activity.maxParticipants}}人
            <text wx:if="{{isHotActivity}}" class="text-xs text-error ml-2">🔥热门</text>
          </text>
          <text wx:if="{{activity.isFull}}" class="block text-xs text-warning mt-1">当前已满员，可先候补排队</text>
          <text wx:elif="{{activity.remainingSeats >= 0}}" class="block text-xs text-gray-500 mt-1">还剩 {{activity.remainingSeats}} 个位置</text>
        </view>
      </view>
      
    </view>
    
    <!-- 活动描述 -->
    <view wx:if="{{activity.description}}" class="bg-white p-4 mb-2">
      <text class="block text-lg font-semibold text-gray-900 mb-3">活动详情</text>
      <text class="text-sm text-gray-600 leading-relaxed whitespace-pre-wrap">{{activity.description}}</text>
    </view>

    <!-- 快捷操作 -->
    <view class="bg-white p-4 mb-2">
      <text class="block text-lg font-semibold text-gray-900 mb-3">快捷操作</text>
      <view class="flex gap-3">
        <button class="flex-1 h-88 bg-gray-100 text-sm text-gray-700 rounded-full" bindtap="onCopyActivityText">
          📋 复制文案
        </button>
        <button class="flex-1 h-88 bg-brand-light text-sm text-brand rounded-full" bindtap="onCloneActivity">
          👯‍♂️ 找类似的局
        </button>
      </view>
    </view>
    
    <!-- 发起人信息 -->
    <view class="bg-white p-4 mb-2" bindtap="onCreatorTap">
      <text class="block text-lg font-semibold text-gray-900 mb-3">发起人</text>
      <view class="creator-card flex items-center p-3 rounded-md">
        <t-avatar image="{{activity.creator.avatarUrl}}" size="96rpx" icon="user" />
        <view class="flex-1 ml-3 min-w-0">
          <text class="block text-base font-medium text-gray-900 mb-1">{{activity.creator.nickname || '匿名用户'}}</text>
      </view>
        <t-icon name="chevron-right" size="32rpx" color="#D1D5DB" />
      </view>
    </view>
    
    <!-- 参与者列表 -->
    <view wx:if="{{(isCreator || joinState === 'joined') && activity.participants && activity.participants.length > 0}}" 
          class="bg-white p-4 mb-2">
      <text class="block text-lg font-semibold text-gray-900 mb-3">参与者 ({{activity.participants.length}})</text>
      <view class="flex flex-wrap gap-3">
        <view wx:for="{{activity.participants}}" wx:key="id" class="participant-item flex items-center p-2 rounded-sm">
          <t-avatar image="{{item.user.avatarUrl}}" size="64rpx" icon="user" />
          <view class="flex-1 ml-2 min-w-0">
            <text class="block text-sm text-gray-900 truncate mb-1">{{item.user.nickname || '匿名用户'}}</text>
            <t-tag size="small" variant="light"
                   theme="{{item.status === 'joined' ? 'success' : item.status === 'waitlist' ? 'warning' : 'default'}}">
              {{utils.getStatusText(item.status)}}
            </t-tag>
          </view>
        </view>
      </view>
    </view>
    
    <!-- 讨论区预览 -->
    <view wx:if="{{recentMessages.length > 0}}" class="bg-white p-4 mb-2">
      <view class="flex items-center justify-between mb-3">
        <text class="text-lg font-semibold text-gray-900">讨论区</text>
        <view class="flex items-center" bindtap="onEnterChat">
          <text class="text-sm text-brand">查看更多</text>
          <t-icon name="chevron-right" size="32rpx" color="#5B75FB" />
        </view>
      </view>
      <view wx:for="{{recentMessages}}" wx:key="index" class="discussion-msg-item flex items-start gap-2 {{index < recentMessages.length - 1 ? 'mb-3' : ''}}">
        <image class="discussion-msg-avatar flex-shrink-0 rounded-full" src="{{item.senderAvatar}}" mode="aspectFill" />
        <view class="flex-1 min-w-0">
          <text class="block text-xs text-gray-400 mb-1">{{item.senderNickname}}</text>
          <text class="block text-sm text-gray-900 line-clamp-2">{{item.content}}</text>
        </view>
      </view>
    </view>
    
    <!-- 底部操作栏 -->
    <view class="bottom-bar flex items-center px-4 py-3">
      <button class="share-btn flex flex-col items-center justify-center w-100 h-100 text-xs text-gray-600" open-type="share">
        <t-icon name="share" size="40rpx" />
        <text>分享</text>
      </button>
      
      <button wx:if="{{isCreator || joinState === 'joined'}}" 
              class="chat-btn flex flex-col items-center justify-center w-100 h-100 text-xs text-gray-600 ml-2" 
              bindtap="onEnterChat">
        <t-icon name="chat" size="40rpx" />
        <text>讨论区</text>
      </button>
      
      <!-- 举报入口（非创建者可见） -->
      <button wx:if="{{!isCreator}}" 
              class="report-btn flex flex-col items-center justify-center w-100 h-100 text-xs text-gray-600 ml-2" 
              bindtap="onReportTap">
        <t-icon name="flag" size="40rpx" />
        <text>举报</text>
      </button>
      
      <button wx:if="{{!isCreator && activity.canJoin}}" 
              class="join-btn flex-1 h-88 ml-4 text-white text-lg font-medium rounded-full" 
              bindtap="onJoinTap">
        {{activity.isFull ? '候补排队' : '我要报名'}}
      </button>
      
      <view wx:elif="{{joinState && !isCreator}}" 
            class="flex-1 flex items-center justify-center h-88 ml-4 bg-gray-100 text-gray-400 text-lg rounded-full">
        <text>{{utils.getStatusText(joinState)}}</text>
      </view>
      
      <view wx:elif="{{isCreator}}" class="flex-1 ml-4">
        <button class="manage-btn w-full h-88 text-white text-lg font-medium rounded-full" bindtap="onManageActivity">管理活动</button>
      </view>
    </view>
  </view>
  
  <!-- 活动管理操作面板 -->
  <t-action-sheet
    visible="{{showManageSheet}}"
    items="{{manageActions}}"
    bind:selected="onManageActionSelect"
    bind:cancel="onManageSheetClose"
    bind:close="onManageSheetClose"
  />
  
  <!-- 手机号绑定半屏 -->
  <auth-sheet 
    visible="{{isAuthSheetVisible}}" 
    bind:success="onAuthSuccess"
    bind:pendingaction="onPendingAction"
    bind:close="onAuthClose"
  />
  
  <!-- 举报弹窗 -->
  <report-sheet
    visible="{{showReportSheet}}"
    type="activity"
    targetId="{{activityId}}"
    bind:close="onReportClose"
    bind:success="onReportSuccess"
  />
</view>
