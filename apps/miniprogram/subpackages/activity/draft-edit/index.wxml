<!--
  草稿编辑页面
  Requirements: 6.8, 15.4, CP-19
-->
<wxs module="utils">
  function getTypeLabel(type) {
    var map = {
      food: '美食', entertainment: '娱乐', sports: '运动',
      boardgame: '桌游', mahjong: '麻将', hotpot: '火锅',
      ktv: 'KTV', movie: '电影', game: '游戏',
      drink: '喝酒', coffee: '咖啡', hiking: '徒步', other: '其他'
    };
    return map[type] || '其他';
  }
  module.exports = { getTypeLabel: getTypeLabel };
</wxs>

<view class="draft-edit-page">
  <!-- 自定义导航栏 -->
  <custom-navbar 
    title="确认发布" 
    showMenu="{{false}}" 
    showMore="{{false}}"
    showBack="{{true}}"
  />

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="draft-edit-page__loading">
    <t-loading theme="circular" size="80rpx" />
    <text class="draft-edit-page__loading-text">加载中...</text>
  </view>

  <!-- 编辑表单 -->
  <view wx:else class="draft-edit-page__content">
    <!-- 活动类型标签 -->
    <view class="draft-edit-page__type-row">
      <view class="type-tag draft-edit-page__type-tag">
        {{utils.getTypeLabel(draft.type)}}
      </view>
      <text class="draft-edit-page__type-label">活动类型</text>
    </view>

    <!-- 标题编辑 -->
    <view class="form-card draft-edit-page__card">
      <view class="draft-edit-page__field-header">
        <t-icon name="edit" size="36rpx" color="#FF6B35" />
        <text class="draft-edit-page__field-title">活动标题</text>
      </view>
      <t-input
        placeholder="请输入活动标题"
        value="{{draft.title}}"
        maxlength="{{50}}"
        bindinput="onTitleInput"
      />
    </view>

    <!-- 时间编辑 -->
    <view class="form-card draft-edit-page__card" bindtap="showTimePicker">
      <view class="draft-edit-page__field-header">
        <t-icon name="time" size="36rpx" color="#FF6B35" />
        <text class="draft-edit-page__field-title">活动时间</text>
        <view wx:if="{{isExpired}}" class="expired-tag draft-edit-page__expired-tag">
          已过期
        </view>
      </view>
      <view class="draft-edit-page__field-row">
        <text class="draft-edit-page__field-value {{isExpired ? 'draft-edit-page__field-value--error' : ''}}">{{formattedTime}}</text>
        <t-icon name="chevron-right" size="40rpx" color="#D1D5DB" />
      </view>
    </view>

    <!-- 地点信息 -->
    <view class="form-card draft-edit-page__card">
      <view class="draft-edit-page__field-header">
        <t-icon name="location" size="36rpx" color="#FF6B35" />
        <text class="draft-edit-page__field-title">活动地点</text>
      </view>
      <view class="draft-edit-page__field-row draft-edit-page__field-row--spaced" bindtap="onAdjustLocation">
        <text class="draft-edit-page__field-value draft-edit-page__field-value--truncate">{{draft.locationName || '请选择地点'}}</text>
        <view class="adjust-btn draft-edit-page__adjust-btn">
          <t-icon name="location" size="28rpx" />
          <text>调整位置</text>
        </view>
      </view>
      <view wx:if="{{draft.address}}" class="draft-edit-page__address">{{draft.address}}</view>
      
      <!-- 位置备注 -->
      <view class="draft-edit-page__hint-section">
        <text class="draft-edit-page__hint-label">位置备注（帮助参与者找到你）</text>
        <t-input
          placeholder="如：4楼平台入口、星巴克门口"
          value="{{draft.locationHint}}"
          maxlength="{{50}}"
          bindinput="onLocationHintInput"
        />
      </view>
    </view>

    <!-- 人数信息 -->
    <view class="form-card draft-edit-page__card">
      <view class="draft-edit-page__field-header">
        <t-icon name="user" size="36rpx" color="#FF6B35" />
        <text class="draft-edit-page__field-title">参与人数</text>
        <text class="draft-edit-page__participants">{{draft.maxParticipants}}人</text>
      </view>
    </view>

    <!-- 发布按钮 -->
    <view class="draft-edit-page__footer">
      <t-button
        theme="primary"
        size="large"
        block
        loading="{{submitting}}"
        disabled="{{submitting || isExpired}}"
        bindtap="onConfirmPublish"
      >
        {{isExpired ? '时间已过期，请修改' : '确认发布'}}
      </t-button>
      <view class="draft-edit-page__footer-hint">
        发布后将消耗 1 次创建活动额度
      </view>
    </view>
  </view>

  <!-- 时间选择器 -->
  <t-date-time-picker
    visible="{{showTimePicker}}"
    mode="minute"
    value="{{draft.startAt}}"
    title="选择活动时间"
    cancelBtn="取消"
    confirmBtn="确定"
    start="{{Date.now()}}"
    bind:change="onTimeChange"
    bind:cancel="onTimePickerCancel"
  />
</view>
