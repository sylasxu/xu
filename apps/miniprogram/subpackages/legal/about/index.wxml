<!--
  关于 xu 页面
  Requirements: 8.1, 8.2, 8.3, 8.4
-->
<view class="about-page page">
  <!-- 自定义导航栏 -->
  <custom-navbar title="关于 xu" bind:back="onBack" />

  <!-- 页面内容 -->
  <view class="content about-page__content">
    <!-- Logo 和版本信息 -->
    <view class="logo-section about-page__card about-page__card--hero">
      <image 
        class="logo-image" 
        src="/static/logo.png" 
        mode="aspectFit"
      />
      <text class="about-page__brand">xu</text>
      <text class="about-page__version">v{{version}}</text>
      <text class="about-page__slogan">碎片化社交助理</text>
    </view>

    <!-- 微信群入口 -->
    <view class="qr-section about-page__card">
      <view class="about-page__section-header">
        <text class="about-page__section-title">遇到问题？加入官方群</text>
      </view>
      <view class="qr-container about-page__qr-container">
        <image 
          class="qr-image" 
          src="{{qrCodeUrl}}" 
          mode="aspectFit"
          bindtap="onPreviewQrCode"
          bindlongpress="onSaveQrCode"
        />
        <text class="about-page__qr-hint">长按保存二维码，微信扫码加入</text>
      </view>
    </view>

    <!-- 法务链接 -->
    <t-cell-group class="about-page__cell-group">
      <t-cell 
        title="用户协议" 
        arrow 
        hover
        bindtap="onViewUserAgreement"
      />
      <t-cell 
        title="隐私政策" 
        arrow 
        hover
        bindtap="onViewPrivacyPolicy"
      />
    </t-cell-group>

    <!-- 版权信息 -->
    <view class="copyright about-page__copyright">
      <text class="about-page__copyright-text">© 2024 xu</text>
    </view>
  </view>
</view>
