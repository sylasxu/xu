{
  "name": "juchang",
  "version": "1.0.0",
  "description": "聚场 - AI碎片化社交找搭子平台",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "--- LIFECYCLE ---": "echo '生命周期脚本'",
    "setup": "bun run env:init && bun install && bun run docker:up && echo '等待数据库启动...' && sleep 5 && bun run db:push",
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules **/*/node_modules",
    "--- ENV ---": "echo '环境变量管理'",
    "env:init": "node scripts/init-env.js",
    "--- DOCKER ---": "echo '基础设施控制'",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:restart": "bun run docker:down && bun run docker:up",
    "--- DATABASE ---": "echo '数据库管理 (Drizzle)'",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:push": "turbo run db:push",
    "db:studio": "turbo run db:studio",
    "db:reset": "bun run docker:down && bun run docker:up && sleep 3 && bun run db:push",
    "db:seed": "turbo run seed --filter=@juchang/db",
    "db:seed:ai-configs": "bun --cwd packages/db src/seed-ai-configs.ts",
    "--- DEVELOPMENT ---": "echo '开发启动'",
    "dev": "turbo run dev --filter=@juchang/api --filter=@juchang/admin --filter=@juchang/web",
    "dev:all": "turbo run dev",
    "dev:api": "turbo run dev --filter=@juchang/api",
    "dev:admin": "turbo run dev --filter=@juchang/admin",
    "dev:mp": "turbo run dev --filter=@juchang/miniprogram",
    "dev:web": "turbo run dev --filter=@juchang/web",
    "dev:api:clean": "node scripts/dev-api-clean.js",
    "dev:full": "node scripts/dev-with-api-watch.js",
    "--- API GENERATION ---": "echo 'API 代码生成'",
    "gen:api": "turbo run gen:api",
    "gen:api:mp": "turbo run gen:api --filter=@juchang/miniprogram",
    "gen:api:watch": "node scripts/watch-api-changes.js",
    "gen:genui-contract": "turbo run gen:contract --filter=@juchang/genui-contract",
    "genui:regression:turns": "turbo run genui:regression:turns --filter=@juchang/api",
    "genui:regression:parity": "turbo run genui:regression:parity --filter=@juchang/api",
    "genui:regression:snapshot": "turbo run genui:regression:snapshot --filter=@juchang/api",
    "genui:regression": "turbo run genui:regression --filter=@juchang/api",
    "arch:check": "bun scripts/architecture-consistency-check.ts",
    "--- QUALITY ---": "echo '代码质量检查'",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "type-check": "turbo run type-check"
  },
  "keywords": [
    "社交",
    "找搭子",
    "LBS",
    "小程序",
    "Next.js"
  ],
  "author": "Juchang Team",
  "license": "MIT",
  "packageManager": "bun@1.3.4",
  "devDependencies": {
    "tsx": "^4.20.6",
    "turbo": "^2.6.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.4"
  },
  "overrides": {
    "@sinclair/typebox": "^0.34.8",
    "typescript": "^5.9.3",
    "@types/node": "^24.10.1"
  },
  "dependencies": {}
}
