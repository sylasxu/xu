{
  "name": "structured-action-auth-gate",
  "description": "未登录写动作会被 /ai/chat 主链统一替换为登录提示，不再注入影子动作",
  "steps": [
    {
      "input": {
        "type": "action",
        "action": "confirm_publish",
        "actionId": "snapshot_confirm_publish_1",
        "displayText": "就按这个发布",
        "params": {
          "activityId": "draft_fixture_1",
          "title": "周五桌游局",
          "locationName": "观音桥"
        }
      },
      "expected": {
        "blocks": [
          {
            "type": "alert",
            "dedupeKey": "auth_required_for_action",
            "replacePolicy": "replace",
            "level": "warning",
            "message": "这个操作会创建或修改活动，先登录后我再继续帮你完成。"
          }
        ]
      }
    }
  ]
}
