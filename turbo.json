{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["**/.env.*local"],
  "tasks": {
    "build": {
      "dependsOn": ["^build", "gen:api", "gen:contract"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["NODE_ENV", "API_PORT", "DATABASE_URL", "JWT_SECRET", "NEXT_PUBLIC_API_URL"]
    },
    "@xu/miniprogram#dev": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["gen:api"]
    },
    "start": {
      "cache": false,
      "persistent": true,
      "dependsOn": ["build"]
    },
    "gen:api": {
      "cache": false,
      "dependsOn": ["^build"],
      "outputs": [
        "**/src/api/endpoints/**",
        "**/src/api/model/**",
        "**/generated.ts",
        "**/generated/**"
      ],
      "inputs": [
        "orval.config.ts",
        "orval.config.js",
        "scripts/export-openapi.ts",
        "../api/src/**/*.ts",
        "../api/src/**/*.js"
      ]
    },
    "gen:contract": {
      "cache": false,
      "outputs": [
        "apps/web/src/gen/**",
        "apps/miniprogram/src/gen/**"
      ],
      "inputs": [
        "packages/genui-contract/src/**/*.ts",
        "packages/genui-contract/schema/**/*.json",
        "packages/genui-contract/fixtures/**/*.json",
        "scripts/gen-genui-contract.ts"
      ]
    },
    "genui:regression:turns": {
      "cache": false
    },
    "genui:regression:parity": {
      "cache": false
    },
    "genui:regression:snapshot": {
      "cache": false
    },
    "genui:regression": {
      "cache": false
    },
    "db:generate": {
      "cache": false,
      "outputs": ["drizzle/**"]
    },
    "db:migrate": {
      "cache": false,
      "dependsOn": ["db:generate"]
    },
    "db:push": {
      "cache": false,
      "interactive": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build", "gen:api", "gen:contract"]
    },
    "format": {
      "cache": false
    },
    "type-check": {
      "dependsOn": ["^build", "gen:api", "gen:contract"]
    },
    "clean": {
      "cache": false
    },
    "seed": {
      "cache": false,
      "dependsOn": ["db:push"]
    }
  }
}
